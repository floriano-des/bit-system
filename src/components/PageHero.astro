---
interface Props {
  eyebrow?: string;
  title: string;
  summary: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="hero-summary">{summary}</p>
  </div>
</section>
