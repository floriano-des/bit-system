---
interface PreviewCard {
  title: string;
  type: string;
  href: string;
  summary: string;
  theme: 'dark' | 'light' | 'mix';
}

interface Props {
  items: PreviewCard[];
}

const { items } = Astro.props;
---

<div class="template-preview-grid">
  {items.map((item) => (
    <a class="template-preview-card" href={item.href}>
      <div class:list={['template-canvas', `theme-${item.theme}`]}>
        <div class="template-frame">
          <div class="template-topbar">
            <span></span>
            <span></span>
            <span></span>
          </div>
          {item.type === 'presentation' && (
            <div class="template-scene template-scene-deck">
              <div class="deck-kicker"></div>
              <div class="deck-title"></div>
              <div class="deck-row">
                <div></div>
                <div></div>
              </div>
            </div>
          )}
          {item.type === 'proposal' && (
            <div class="template-scene template-scene-proposal">
              <div class="proposal-header"></div>
              <div class="proposal-lines">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="proposal-boxes">
                <div></div>
                <div></div>
              </div>
            </div>
          )}
          {item.type === 'landing-page' && (
            <div class="template-scene template-scene-landing">
              <div class="landing-hero"></div>
              <div class="landing-cta"></div>
              <div class="landing-grid">
                <div></div>
                <div></div>
                <div></div>
              </div>
            </div>
          )}
        </div>
      </div>
      <div class="template-copy">
        <span class="card-meta">{item.type}</span>
        <h2>{item.title}</h2>
        <p>{item.summary}</p>
        <span class="card-link">Abrir template</span>
      </div>
    </a>
  ))}
</div>
