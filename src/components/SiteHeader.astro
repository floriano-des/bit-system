---
import { navItems } from '../data/site';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">Bit</span>
      <span class="brand-copy">
        <strong>Bit System</strong>
        <small>2P Growth Lab</small>
      </span>
    </a>

    <nav class="nav" aria-label="Principal">
      {navItems.map((item) => (
        <a href={item.href} class:list={{ active: Astro.url.pathname.startsWith(item.href) && item.href !== '/' }}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
