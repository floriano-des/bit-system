---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { tokenGroups } from '../data/tokens';
---

<Layout title="Tokens | Bit System" description="Tokens semânticos e escalas base do Bit System.">
  <PageHero
    eyebrow="Tokens"
    title="Camada semântica para design, web e IA"
    summary="Os tokens desta v1 traduzem o que hoje está espalhado no Figma para uma estrutura nomeada por intenção e pronta para evoluir."
  />

  <section class="section">
    <div class="container">
      <div class="card-grid">
        <article class="card">
          <span class="card-meta">primitive</span>
          <h2>Paleta e escala bruta</h2>
          <p>Cores, spacing e tipografia começam como valores base. Essa camada evita improviso e facilita herança posterior.</p>
        </article>
        <article class="card">
          <span class="card-meta">semantic</span>
          <h2>Nomes orientados ao uso</h2>
          <p>O portal privilegia nomes como `color.bg.brand.primary` e `type.body.md`, porque eles comunicam intenção e não só aparência.</p>
        </article>
        <article class="card">
          <span class="card-meta">operational</span>
          <h2>Pronto para docs e IA</h2>
          <p>A estrutura de tokens precisa servir o Figma, o front end, os templates e os playbooks de geração assistida.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container token-layout">
      {tokenGroups.map((group) => (
        <article class="token-group" id={group.id}>
          <h2>{group.title}</h2>
          <p class="section-summary">{group.description}</p>
          <table class="token-table">
            <thead>
              <tr>
                <th>Token</th>
                <th>Valor</th>
                <th>Uso recomendado</th>
              </tr>
            </thead>
            <tbody>
              {group.items.map((item) => (
                <tr>
                  <td>{item.name}</td>
                  <td>
                    {item.value.startsWith('#') && <span class="swatch" style={`background:${item.value}`}></span>}
                    {item.value}
                  </td>
                  <td>{item.usage}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </article>
      ))}
    </div>
  </section>
</Layout>
