---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { tokenGroups } from '../data/tokens';
---

<Layout title="Tokens | Bit System" description="Tokens semânticos e escalas base do Bit System.">
  <PageHero
    eyebrow="Tokens"
    title="Camada semântica para design, web e IA"
    summary="Os tokens desta v1 traduzem o que hoje está espalhado no Figma para uma estrutura nomeada por intenção e pronta para evoluir."
  />

  <section class="section">
    <div class="container token-layout">
      {tokenGroups.map((group) => (
        <article class="token-group" id={group.id}>
          <h2>{group.title}</h2>
          <p class="section-summary">{group.description}</p>
          <table class="token-table">
            <thead>
              <tr>
                <th>Token</th>
                <th>Valor</th>
                <th>Uso recomendado</th>
              </tr>
            </thead>
            <tbody>
              {group.items.map((item) => (
                <tr>
                  <td>{item.name}</td>
                  <td>
                    {item.value.startsWith('#') && <span class="swatch" style={`background:${item.value}`}></span>}
                    {item.value}
                  </td>
                  <td>{item.usage}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </article>
      ))}
    </div>
  </section>
</Layout>
