---
import { getCollection } from 'astro:content';
import CardGrid from '../../components/CardGrid.astro';
import PageHero from '../../components/PageHero.astro';
import Layout from '../../layouts/Layout.astro';

const patterns = (await getCollection('patterns'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    href: `/patterns/${entry.id}/`,
    title: entry.data.title,
    summary: entry.data.summary,
    meta: entry.data.channel,
  }));
---

<Layout title="Patterns | Bit System">
  <PageHero
    eyebrow="Patterns"
    title="Estruturas recorrentes para decks, propostas e páginas"
    summary="Patterns formalizam blocos recorrentes da operação da 2P para reduzir improviso e facilitar geração assistida por IA."
  />

  <section class="section">
    <div class="container">
      <div class="card-grid">
        <article class="card">
          <span class="card-meta">deck</span>
          <h2>Narrativa em sequência</h2>
          <p>Problema, leitura, solução, prova e próximo passo. O pattern organiza ritmo e evita slides aleatórios.</p>
        </article>
        <article class="card">
          <span class="card-meta">landing</span>
          <h2>Escaneável desde o topo</h2>
          <p>Hero, prova, explicação, oferta e CTA. A estrutura protege conversão e clareza mesmo quando o conteúdo muda.</p>
        </article>
        <article class="card">
          <span class="card-meta">sistema</span>
          <h2>Composição antes de exceção</h2>
          <p>Patterns evitam criar componentes novos quando o problema real está na ordenação de blocos e na narrativa do artefato.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <CardGrid items={patterns} />
    </div>
  </section>
</Layout>
