---
import { getCollection } from 'astro:content';
import CardGrid from '../../components/CardGrid.astro';
import FoundationVisuals from '../../components/FoundationVisuals.astro';
import PageHero from '../../components/PageHero.astro';
import Layout from '../../layouts/Layout.astro';

const foundations = (await getCollection('foundations'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    href: `/foundations/${entry.id}/`,
    title: entry.data.title,
    summary: entry.data.summary,
    meta: entry.data.category,
  }));
---

<Layout title="Foundations | Bit System">
  <PageHero
    eyebrow="Foundations"
    title="Base visual e semântica do Bit System"
    summary="Cores, tipografia e layout são tratados aqui como infraestrutura de sistema, não como escolha estética isolada."
  />

  <section class="section">
    <div class="container">
      <FoundationVisuals />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Documentação por foundation</h2>
      <p class="section-summary">
        Cada foundation tem uma página com racional, regras de uso e impacto operacional para design, conteúdo, front end e IA.
      </p>
      <CardGrid items={foundations} />
    </div>
  </section>
</Layout>
