---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Página não encontrada | Bit System"
  description="A página solicitada não existe no portal público do Bit System."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Erro 404</p>
      <h1>Página não encontrada</h1>
      <p class="hero-summary">
        O conteúdo pode ter sido movido, renomeado ou ainda não publicado nesta versão do portal.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href="/">Voltar para a home</a>
        <a class="button button-secondary" href="/search">Ir para a busca</a>
      </div>
    </div>
  </section>
</Layout>
