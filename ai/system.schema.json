{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bit-system/ai/system.schema.json",
  "title": "Bit System AI Package Index",
  "type": "object",
  "required": [
    "metadata",
    "preferred_reading_order",
    "source_of_truth",
    "trust_order",
    "contracts",
    "global_rules"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["system", "version", "updated", "purpose"],
      "properties": {
        "system": { "type": "string" },
        "version": { "type": "string" },
        "updated": { "type": "string" },
        "purpose": { "type": "string" }
      }
    },
    "preferred_reading_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "trust_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "purpose"],
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },
    "global_rules": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
